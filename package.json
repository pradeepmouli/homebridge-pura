{
  "name": "homebridge-pura",
  "displayName": "Pura Smart Fragrance Diffuser",
  "type": "module",
  "version": "1.0.0",
  "description": "Homebridge plugin for Pura smart fragrance diffusers",
  "author": "pradeepmouli",
  "license": "Apache-2.0",
  "homepage": "https://github.com/pradeepmouli/homebridge-pura#readme",
  "repository": {
